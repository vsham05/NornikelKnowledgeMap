# =============================================================================
# Docker deploy — copy to .env.docker, then start the stack
# =============================================================================
#
#   Linux/macOS:  cp .env.example .env.docker && ./start-docker.sh
#   Windows:      copy .env.example .env.docker && start-docker.bat
#
# Models are pulled automatically inside Docker on first start (~10 GB).
# =============================================================================

# --- Neo4j (must match docker-compose NEO4J_AUTH) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# --- MinIO (must match docker-compose MINIO_ROOT_*) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scientific-docs

# --- LLM via Ollama (runs in Docker) ---
# default:  qwen3:8b            (~5–6 GB VRAM)
# light:    qwen2.5:7b-instruct (~8 GB VRAM)
# standard: qwen2.5:14b-instruct (~16 GB VRAM)
LLM_API_KEY=ollama
LLM_MODEL=qwen3:8b
LLM_PROVIDER=local
LLM_CONTEXT_TOKENS=32768
LLM_EXTRACTION_MAX_CHARS=20000
LLM_YANDEX_FALLBACK_LOCAL=true
# When true (default): probe Yandex at startup; if unreachable or a call fails, route to local Ollama automatically.
EXTRACTION_LANGUAGE=auto

# --- Hybrid ingest (page count → Yandex for long docs when API is up; else local) ---
INGEST_HYBRID_ROUTING=true
INGEST_LOCAL_MAX_PAGES=28
INGEST_LOCAL_FULL_COVERAGE=true
INGEST_LOCAL_ENRICHER_CONCURRENCY=0
INGEST_FAST_PAGE_THRESHOLD=35
INGEST_EMBED_MAX_CHUNKS=0
INGEST_PARALLEL_EXTRACTION_BATCHES=8
INGEST_LLM_CONCURRENCY=2
INGEST_TARGET_MAX_MINUTES=15
INGEST_ENRICHER_MULTIPASS=0
INGEST_TABLE_VLM=true
INGEST_TABLE_VLM_MAX=24

# --- Embeddings + vision (pulled by ollama-pull on first start) ---
EMBEDDING_MODEL=mxbai-embed-large
VLM_MODEL=minicpm-v

# --- Yandex AI Studio (optional) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=qwen3-235b-a22b-fp8/latest
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1

# Russian RAG: translate question→EN for search, synthesize answer in EN, translate→RU
RAG_RU_TRANSLATE_PIPELINE=true

# --- Frontend (URL the browser uses to reach the API) ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Models pulled on first docker compose up (comma-separated) ---
# light:    qwen2.5:7b-instruct,mxbai-embed-large,minicpm-v
# standard: qwen2.5:14b-instruct,mxbai-embed-large,minicpm-v
# premium:  qwen2.5:32b-instruct,mxbai-embed-large,minicpm-v
OLLAMA_PULL_MODELS=qwen3:8b,mxbai-embed-large,minicpm-v
