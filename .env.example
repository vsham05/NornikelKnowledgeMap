# =============================================================================
# Deploy — copy to .env.docker, install Ollama, then run start-docker.bat
# =============================================================================
#
#   1. Install Docker Desktop:  https://www.docker.com/products/docker-desktop/
#   2. Install Ollama:          https://ollama.com/download
#   3. Pull models (one-time, in a terminal):
#        ollama pull qwen2.5:7b-instruct
#        ollama pull mxbai-embed-large
#        ollama pull minicpm-v
#   4. copy .env.example .env.docker
#   5. .\start-docker.bat
#
# =============================================================================

# --- Neo4j (must match docker-compose NEO4J_AUTH) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# --- MinIO (must match docker-compose MINIO_ROOT_*) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scientific-docs

# --- LLM via Ollama on your PC (host.docker.internal from Docker backend) ---
# light:    qwen2.5:7b-instruct   (~8 GB VRAM)
# standard: qwen2.5:14b-instruct  (~16 GB VRAM)
# premium:  qwen2.5:32b-instruct  (~24 GB VRAM)
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_PROVIDER=local
LLM_CONTEXT_TOKENS=8192
LLM_EXTRACTION_MAX_CHARS=12000
LLM_YANDEX_FALLBACK_LOCAL=true
EXTRACTION_LANGUAGE=auto

# --- Hybrid ingest (large PDFs → Yandex when keys are set below) ---
INGEST_HYBRID_ROUTING=true
INGEST_LOCAL_MAX_PAGES=28
INGEST_LOCAL_FULL_COVERAGE=true
INGEST_LOCAL_ENRICHER_CONCURRENCY=0
INGEST_FAST_PAGE_THRESHOLD=35
INGEST_EMBED_MAX_CHUNKS=0
INGEST_PARALLEL_EXTRACTION_BATCHES=8
INGEST_LLM_CONCURRENCY=8
INGEST_TARGET_MAX_MINUTES=15
INGEST_ENRICHER_MULTIPASS=0
INGEST_TABLE_VLM=true
INGEST_TABLE_VLM_MAX=24

# --- Embeddings + vision (same Ollama app on your PC) ---
EMBEDDING_MODEL=mxbai-embed-large
VLM_MODEL=minicpm-v

# --- Yandex AI Studio (optional) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=qwen3-235b-a22b-fp8/latest
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1

# --- Frontend (URL the browser uses to reach the API) ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
