# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Qdrant
QDRANT_URL=http://localhost:6333

# Local LLM (Ollama) — tiered for Yandex parity
# premium:  qwen2.5:32b-instruct  (~88% Yandex extraction context, 24GB+ VRAM)
# standard: qwen2.5:14b-instruct  (~44%, 16GB VRAM)
# light:    qwen2.5-7b-instruct   (~19%, fast; 2-pass enricher on long PDFs)
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5-7b-instruct
LLM_PROVIDER=local
LLM_CONTEXT_TOKENS=8192
LLM_EXTRACTION_MAX_CHARS=12000
LLM_EXTRACTION_MAX_BATCHES=24
LLM_YANDEX_FALLBACK_LOCAL=true
EXTRACTION_LANGUAGE=auto
# Hybrid ingest: PDFs with more pages → Yandex API; ≤ limit → local 7B
INGEST_HYBRID_ROUTING=true
INGEST_LOCAL_MAX_PAGES=28
INGEST_LOCAL_FULL_COVERAGE=true
INGEST_LOCAL_ENRICHER_CONCURRENCY=0
INGEST_FAST_PAGE_THRESHOLD=35
INGEST_EMBED_MAX_CHUNKS=0
LLM_EXTRACTION_MAX_BATCHES=0
INGEST_PARALLEL_EXTRACTION_BATCHES=8
INGEST_LLM_CONCURRENCY=8
INGEST_TARGET_MAX_MINUTES=15
INGEST_ENRICHER_MULTIPASS=0

# Yandex AI Studio (reference: qwen3-235b @ 64K chars / 262K ctx)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# qwen3-235b = best quality; deepseek-v4-flash = faster on very long PDFs
YANDEX_MODEL=qwen3-235b-a22b-fp8/latest
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1

# Embeddings (Ollama)
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_BASE_URL=http://localhost:11434/v1

# Vision model for image-based tables (requires multimodal Ollama model)
# ollama pull minicpm-v
VLM_MODEL=minicpm-v
VLM_BASE_URL=http://localhost:11434/v1
INGEST_TABLE_VLM=true
INGEST_TABLE_VLM_MAX=24
